# ============================================================================
# .dockerignore para FRONTEND (Next.js)
# ============================================================================

# ----------------------------------------------------------------------------
# Node.js
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# node_modules/: 200-500MB de dependencias
# Se reinstalan con npm ci en el Dockerfile

# ----------------------------------------------------------------------------
# Next.js
# ----------------------------------------------------------------------------
.next/
out/
.cache/
.swc/

# .next/: Build anterior (se genera nuevo en Docker)
# out/: Export estático anterior
# .swc/: Cache del compilador SWC

# ----------------------------------------------------------------------------
# Variables de Entorno
# ----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env*.local

# Variables de entorno se pasan via docker-compose

# ----------------------------------------------------------------------------
# Control de Versiones
# ----------------------------------------------------------------------------
.git
.gitignore

# ----------------------------------------------------------------------------
# IDEs
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp

# ----------------------------------------------------------------------------
# Sistema Operativo
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------------
# Documentación
# ----------------------------------------------------------------------------
README.md
*.md

# ----------------------------------------------------------------------------
# Scripts de Windows
# ----------------------------------------------------------------------------
*.bat
start.ps1

# No funcionan en Linux

# ----------------------------------------------------------------------------
# Archivos antiguos/backup
# ----------------------------------------------------------------------------
*_old.*
*_backup.*
*.bak

# Excluir versiones antiguas de archivos que causan errores de TypeScript

# ============================================================================
# RESULTADO:
# Contexto de build del frontend: ~10MB (solo código TypeScript/React)
# vs 300MB sin .dockerignore (incluiría node_modules, .next, etc.)
# ============================================================================
